#!/usr/bin/env bash

magenta="\033[1;35m"
green="\033[1;32m"
white="\033[1;37m"
blue="\033[1;34m"
red="\033[1;31m"
black="\033[1;40;30m"
yellow="\033[1;33m"
cyan="\033[1;36m"
reset="\033[0m"
bgyellow="\033[1;43;33m"
bgwhite="\033[1;47;37m"
c0=${reset}
c1=${magenta}
c2=${green}
c3=${white}
c4=${blue}
c5=${red}
c6=${yellow}
c7=${cyan}
c8=${black}
c9=${bgyellow}
c10=${bgwhite}

function getCodeName() {
  codename="$(getprop ro.product.board)"
}

function getClientBase() {
  client_base="$(getprop ro.com.google.clientidbase)"
}

function getModel() {
  model="$(getprop ro.product.brand) $(getprop ro.product.model)"
}

function getDistro() {
  os="$(uname -o) $(uname -m)"
}

function getKernel() {
  kernel="$(uname -r | cut -d '-' -f 1-4)"
}

function getTotalPackages() {
   if command -v dpkg-query >/dev/null 2>&1; then
      packages=$(dpkg-query -f '${binary:Package}\n' -W | wc -l)
   elif command -v pkg >/dev/null 2>&1; then
      packages=$(pkg list-installed 2>/dev/null | wc -l)
      # Kurangi 1 jika ada baris "Listing..."
      if pkg list-installed 2>/dev/null | grep -q "Listing..."; then
         packages=$((packages - 1))
      fi
   elif command -v apt >/dev/null 2>&1; then
      packages=$(apt list --installed 2>/dev/null | wc -l)
      if apt list --installed 2>/dev/null | grep -q "Listing..."; then
         packages=$((packages - 1))
      fi
   else
      packages="Unknown"
   fi
}

function getShell() {
  shell="$(basename $SHELL)"
}

function getUptime() {
  local raw weeks days hours minutes total_days parts
  raw="$(uptime --pretty | sed 's/up //')"
  
  weeks=$(echo "$raw" | grep -oE '[0-9]+ week' | awk '{print $1}')
  days=$(echo "$raw" | grep -oE '[0-9]+ day' | awk '{print $1}')
  hours=$(echo "$raw" | grep -oE '[0-9]+ hour' | awk '{print $1}')
  minutes=$(echo "$raw" | grep -oE '[0-9]+ minute' | awk '{print $1}')
  
  total_days=$(( ${weeks:-0} * 7 + ${days:-0} ))
  
  parts=()
  if [ $total_days -gt 0 ]; then
    if [ $total_days -eq 1 ]; then
      parts+=("1 day")
    else
      parts+=("$total_days days")
    fi
  fi
  
  if [ -n "$hours" ]; then
    if [ "$hours" -eq 1 ]; then
      parts+=("1 hour")
    else
      parts+=("$hours hours")
    fi
  fi
  
  if [ -n "$minutes" ]; then
    if [ "$minutes" -eq 1 ]; then
      parts+=("1 minute")
    else
      parts+=("$minutes minutes")
    fi
  fi
  
  uptime=$(printf ", %s" "${parts[@]}")
  uptime=${uptime:2}
}

function getMemoryUsage() {
  #memory="$(free --mega | sed -n -E '2s/^[^0-9]*([0-9]+) *([0-9]+).*/'"${space}"'\2 \/ \1MB/p')"
  _MEM="Mem:"
  _GREP_ONE_ROW="$(free --mega | grep "${_MEM}")"
  _TOTAL="$(echo ${_GREP_ONE_ROW} | awk '{print $2}')"
  _USED="$(echo ${_GREP_ONE_ROW} | awk '{print $3}')"

  memory="${_USED}MB / ${_TOTAL}MB"
}

function getDiskUsage() {
  _MOUNTED_ON="/storage/emulated"
  _GREP_ONE_ROW="$(df -h | grep ${_MOUNTED_ON} | head -n 1)"
  _SIZE="$(echo ${_GREP_ONE_ROW} | awk '{print $2}')"
  _USED="$(echo ${_GREP_ONE_ROW} | awk '{print $3}')"
  _AVAIL="$(echo ${_GREP_ONE_ROW} | awk '{print $4}')"
  _USE="$(echo ${_GREP_ONE_ROW} | awk '{print $5}' | sed 's/%//')"
  _MOUNTED="$(echo ${_GREP_ONE_ROW} | awk '{print $6}')"

  storage="${_USED}B / ${_SIZE}B = ${_AVAIL}B (${_USE}%)"
}

function main() {
  getCodeName
  getClientBase
  getModel
  getDistro
  getKernel
  getTotalPackages
  getShell
  getUptime
  getMemoryUsage
  getDiskUsage
}

main

echo -e "\n\n"
